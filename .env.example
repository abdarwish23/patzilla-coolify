# ===========================================
# PatZilla — Environment Variables
# ===========================================
# Works out of the box with FREE sources (no keys needed).
# Add EPO/OPS credentials later for 80+ country coverage.
# ===========================================

# ---- OPTIONAL: EPO/OPS (free, covers 80+ countries) ----
# Register at: https://developers.epo.org/
# Leave empty to use free sources only (DPMA/DEPATISnet)
EPO_OPS_KEY=
EPO_OPS_SECRET=

# ---- OPTIONAL: Port ----
PATZILLA_PORT=6543

# ---- OPTIONAL: IFI CLAIMS (professional paid database) ----
IFI_CLAIMS_URI=
IFI_CLAIMS_URI_JSON=
IFI_CLAIMS_USER=
IFI_CLAIMS_PASS=

# ---- OPTIONAL: depa.tech (paid) ----
DEPATECH_URI=
DEPATECH_USER=
DEPATECH_PASS=

# ---- OPTIONAL: SMTP (for sharing/email features) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
